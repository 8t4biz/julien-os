# Julien OS — variables d'environnement
#
# Copier ce fichier en .env (à la racine du repo en local, ou dans /root/.env
# sur le VPS) et remplir chaque valeur. NE JAMAIS committer .env.

# Telegram
TELEGRAM_TOKEN=

# Anthropic (Claude API)
ANTHROPIC_API_KEY=

# OpenAI (Whisper transcription)
OPENAI_API_KEY=

# Notion (BDD_Notes_Inbox + Tableau de bord)
NOTION_TOKEN=

# Proton Mail
PROTONMAIL_EMAIL=
PROTONMAIL_PASSWORD=
PROTONMAIL_MAILBOX_PASSWORD=
PROTONMAIL_TOTP_SECRET=
# bridge_password généré par Proton Bridge sur le VPS (différent du password compte)
PROTONMAIL_BRIDGE_PASSWORD=

# Airbnb
AIRBNB_EMAIL=
AIRBNB_PASSWORD=
